# =============================================================================
# zinx-threads — environment variables  (copy to `.env.local`, which is git-
# ignored). See SETUP.md for the full walkthrough.
#
# Two homes for values — DON'T mix them up:
#   • FRONTEND  → `.env.local` in the project root. Vite exposes ONLY `VITE_*`
#                 vars to the browser/desktop renderer. Never put secrets here.
#   • CONVEX    → the Convex deployment, set with
#                   npx convex env set <KEY> <value>
#                 (or Convex dashboard → Settings → Environment Variables).
#                 These are server-side secrets and never reach the client.
#
# Tip: `npx convex dev` auto-writes CONVEX_DEPLOYMENT and VITE_CONVEX_URL into
# `.env.local` for you — you usually only paste the WorkOS values by hand.
# =============================================================================


# -----------------------------------------------------------------------------
# FRONTEND  →  .env.local   (safe to ship to the client; VITE_-prefixed)
# -----------------------------------------------------------------------------

# Convex deployment URL the client connects to (realtime data + auth).
# WHERE: auto-written by `npx convex dev`; also in Convex dashboard →
#        Settings → "Deployment URL". Looks like https://<name>.convex.cloud
VITE_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud

# WorkOS AuthKit client id (public; same value as WORKOS_CLIENT_ID below).
# WHERE: WorkOS dashboard → "Get started" / Quick start (also under
#        Configuration). Starts with `client_...`.
VITE_WORKOS_CLIENT_ID=client_XXXXXXXXXXXXXXXXXXXXXXXX

# Where WorkOS sends the user back after login. Must be registered in
# WorkOS dashboard → Redirects. For local WEB dev use the Vite port:
#   web dev:  http://localhost:5173/callback
# Desktop/Electron uses a custom-protocol deep link instead — this var is
# ignored there (the redirect URI is hard-coded to zinx://callback). ALSO
# register `zinx://callback` in WorkOS → Redirects for the desktop app.
VITE_WORKOS_REDIRECT_URI=http://localhost:5173/callback

# LiveKit server URL the renderer connects to for voice/video calls (PUBLIC — not
# a secret; the join token minted by convex/voice.ts is the capability). Local
# `livekit-server --dev` → ws://localhost:7880; prod → wss://<your-livekit-host>.
VITE_LIVEKIT_URL=ws://localhost:7880

# Origin used to build shareable invite links (`/invite/<code>`, `/connect/<token>`).
# Optional — defaults to the current web origin, or http://localhost:5173 on a
# packaged desktop (file://) build. Set to the deployed web app for real links.
VITE_APP_URL=


# -----------------------------------------------------------------------------
# CONVEX DEPLOYMENT  →  `npx convex env set <KEY> <value>`   (SECRETS — server-side)
# Do NOT prefix these with VITE_ and do NOT put them in .env.local.
# -----------------------------------------------------------------------------

# WorkOS API key (SECRET). Used by the Convex WorkOS component to call the
# WorkOS API (user sync, org/directory reads).
# WHERE: WorkOS dashboard → API Keys (or "Get started" / Quick start).
#        Starts with `sk_...`.
WORKOS_API_KEY=sk_XXXXXXXXXXXXXXXXXXXXXXXX

# WorkOS Client id — SAME value as VITE_WORKOS_CLIENT_ID. Used by
# convex/auth.config.ts to validate WorkOS-issued JWTs.
# WHERE: WorkOS dashboard → Quick start / Configuration.
WORKOS_CLIENT_ID=client_XXXXXXXXXXXXXXXXXXXXXXXX

# WorkOS webhook signing secret — verifies the user/org/directory-sync (SCIM)
# webhooks WorkOS POSTs to the Convex component. Without it, syncs are rejected.
# WHERE: WorkOS dashboard → Webhooks → (your Convex endpoint) → Signing Secret.
#        Starts with `wh_...`.  (Only needed once you enable webhook sync/SCIM.)
WORKOS_WEBHOOK_SECRET=wh_XXXXXXXXXXXXXXXXXXXXXXXX

# OPTIONAL — only if you enable AuthKit Actions (custom auth-flow hooks).
# WHERE: WorkOS dashboard → Actions → Signing Secret.
# WORKOS_ACTION_SECRET=

# ── GIF + image search (server-side; proxied through Convex actions, never
#    exposed to the renderer). Set on the Convex deployment too:
#      npx convex env set KLIPY_API_KEY <key>
#      npx convex env set UNSPLASH_ACCESS_KEY <key>
# WHERE: https://klipy.com  ·  https://unsplash.com/developers
KLIPY_API_KEY=
UNSPLASH_ACCESS_KEY=

# ── Cloudflare R2 file uploads (`@convex-dev/r2`, convex/files.ts). All SECRET,
#    set ONLY on the Convex deployment (never in the renderer):
#      npx convex env set R2_TOKEN              <api-token>
#      npx convex env set R2_ACCESS_KEY_ID      <access-key-id>
#      npx convex env set R2_SECRET_ACCESS_KEY  <secret-access-key>
#      npx convex env set R2_ENDPOINT           https://<account-id>.r2.cloudflarestorage.com
#      npx convex env set R2_BUCKET             <bucket-name>
#      npx convex env set R2_PUBLIC_URL         https://<public-bucket-domain>   # see below
# WHERE: Cloudflare dashboard → R2 → create a bucket + an API token (Object R/W).
#   • The bucket needs a CORS rule allowing PUT from the app origin — see SETUP.md.
#   • R2_PUBLIC_URL is the bucket's PUBLIC base URL (enable "Public access" for an
#     r2.dev subdomain, or attach a custom domain). Uploaded avatars are stored as
#     `<R2_PUBLIC_URL>/<key>` so the URL is stable + cacheable. Without it, uploads
#     fall back to a 7-day signed URL (dev only — not permanent).
R2_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=
R2_PUBLIC_URL=

# ── Voice / video calls (LiveKit — self-hosted, open-source SFU, no participant
#    cap). The API key/secret are SECRET and only mint join tokens server-side
#    (convex/voice.ts); set ONLY on the Convex deployment:
#      npx convex env set LIVEKIT_API_KEY     <api-key>
#      npx convex env set LIVEKIT_API_SECRET  <api-secret>
# LOCAL DEV: run `livekit-server --dev` — it prints a dev key/secret
#   (devkey / secret) and listens on ws://localhost:7880 (already in the CSP).
# PROD: deploy livekit-server (Docker) and use your generated key/secret + a
#   `wss://<your-host>` URL (add that origin to the index.html CSP connect-src).
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Resend — transactional email for invitations (member invites + shared-channel
# invites). Component `@convex-dev/resend`; wrapper `convex/resend.ts`.
#      npx convex env set RESEND_API_KEY      re_...
#      npx convex env set RESEND_WEBHOOK_SECRET whsec_...   # only for delivery-event webhook (optional)
#      npx convex env set EMAIL_FROM          "Zinx Threads <contact@zinx.app>"  # sender; must be on the verified domain
#      npx convex env set APP_URL             https://your-app-origin   # invite links (defaults to http://localhost:5173)
# The `from` domain must be verified in the Resend account (contact@zinx.app on the shared one).
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=
APP_URL=
