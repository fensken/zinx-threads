node_modules
dist
out
.DS_Store
.eslintcache
*.log*

# Secrets — never commit. `.env.sample` is the committed template.
.env
.env.local
.env.*.local

# Convex codegen: COMMITTED (not ignored) so CI can typecheck the renderer, which imports
# `@convex/_generated/api` — a clean CI checkout has no deployment to run `convex codegen` against.
# `npx convex dev` regenerates these locally; commit the changes alongside schema/function edits.
# The `ai/` subfolder (AI-guidelines install state) is tooling-local, so it stays ignored.
convex/_generated/ai/

# Excalidraw fonts — copied from the package by `scripts/copy-excalidraw-assets.mjs`
# (a copy of a dependency, not source). See that file for why we self-host them.
src/renderer/public/fonts/
