{
  "name": "zinx-threads",
  "version": "1.0.0",
  "description": "Zinx Threads — team chat, docs, and boards in one place.",
  "main": "./out/main/index.js",
  "author": "Zinx Threads",
  "homepage": "https://zinxthreads.app",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "npm run assets:excalidraw && electron-vite dev",
    "dev:web": "npm run assets:excalidraw && vite --config vite.web.config.ts",
    "build": "npm run assets:excalidraw && npm run typecheck && electron-vite build",
    "build:web": "npm run assets:excalidraw && npm run typecheck:web && vite build --config vite.web.config.ts",
    "preview:web": "vite preview --config vite.web.config.ts",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "release:win": "npm run build && electron-builder --win --publish always",
    "release:mac": "electron-vite build && electron-builder --mac --publish always",
    "release:linux": "electron-vite build && electron-builder --linux --publish always",
    "assets:excalidraw": "node scripts/copy-excalidraw-assets.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@blocknote/ariakit": "^0.51.4",
    "@blocknote/code-block": "^0.51.4",
    "@blocknote/core": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@convex-dev/presence": "^0.3.2",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/r2": "^0.10.2",
    "@convex-dev/resend": "^0.2.5",
    "@convex-dev/workos": "^0.0.3",
    "@excalidraw/excalidraw": "^0.18.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@floating-ui/react": "^0.27.19",
    "@fontsource-variable/funnel-display": "^5.2.8",
    "@livekit/components-react": "^2.9.23",
    "@livekit/components-styles": "^1.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "@shadcn/react": "^0.2.1",
    "@tanstack/react-router": "^1.170.17",
    "@tiptap/extension-image": "3.27.3",
    "@tiptap/extensions": "3.27.3",
    "@tiptap/pm": "3.27.3",
    "@tiptap/react": "3.27.3",
    "@tiptap/starter-kit": "3.27.3",
    "@tiptap/suggestion": "3.27.3",
    "@workos-inc/authkit-react": "^0.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.42.1",
    "convex-helpers": "^0.1.120",
    "date-fns": "^4.4.0",
    "electron-updater": "^6.3.9",
    "embla-carousel-react": "^8.6.0",
    "emoji-picker-react": "^4.12.2",
    "input-otp": "^1.4.2",
    "jose": "^6.2.3",
    "livekit-client": "^2.20.1",
    "next-themes": "^0.4.6",
    "react-colorful": "^5.7.0",
    "react-day-picker": "^10.0.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.1",
    "recharts": "3.9.2",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "use-stick-to-bottom": "^1.1.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "convex-test": "^0.0.54",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.9.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.10"
  }
}
